@model Projeto_eventos.Models.RedefinirSenha

<div class="min-h-screen flex items-center justify-center bg-gray-900 text-gray-100">
    <form asp-action="RedefinirSenha" method="post" class="bg-gray-800 p-8 rounded-2xl w-full max-w-md">
        <h2 class="text-2xl font-bold mb-4 text-center">Redefinir Senha</h2>
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />

        <label class="block mb-2">Nova senha:</label>
        <input asp-for="NovaSenha" type="password" class="w-full px-4 py-2 rounded-lg bg-gray-900 border border-gray-700 mb-4" />

        <label class="block mb-2">Confirmar nova senha:</label>
        <input asp-for="ConfirmarSenha" type="password" class="w-full px-4 py-2 rounded-lg bg-gray-900 border border-gray-700 mb-4" />

        <button type="submit" class="w-full py-2 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg font-bold">
            Redefinir
        </button>
        <div asp-validation-summary="All" class="text-red-500"></div>
    </form>
</div>
