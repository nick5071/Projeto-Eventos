@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Minha Conta";
}

@if (TempData["Sucesso"] != null)
{
    <div id="alerta-sucesso"
         style="z-index:9999"
         class="fixed top-28 left-1/2 transform -translate-x-1/2 bg-green-500/20 border border-green-400 text-green-300 px-6 py-3 rounded-2xl text-center shadow-lg backdrop-blur-md transition-all duration-500 ease-out">
        ✅ @TempData["Sucesso"]
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const alerta = document.getElementById('alerta-sucesso');
            if (alerta) {
                setTimeout(() => {
                    alerta.style.opacity = '0';
                    alerta.style.transform = 'translate(-50%, -20px)';
                    setTimeout(() => alerta.remove(), 200);
                }, 4000);
            }
        });
    </script>
}


@if (TempData["Erro"] != null)
{
    <div id="alerta-sucesso"
         style="z-index:9999"
         class="fixed top-28 left-1/2 transform -translate-x-1/2 bg-green-500/20 border border-red-400 text-red-300 px-6 py-3 rounded-2xl text-center shadow-lg backdrop-blur-md transition-all duration-500 ease-out">
         @TempData["Erro"]
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const alerta = document.getElementById('alerta-sucesso');
            if (alerta) {
                setTimeout(() => {
                    alerta.style.opacity = '0';
                    alerta.style.transform = 'translate(-50%, -20px)';
                    setTimeout(() => alerta.remove(), 200);
                }, 4000);
            }
        });
    </script>
}

<div class="min-h-screen flex flex-col font-sans bg-gray-900 text-gray-100 relative overflow-hidden">
    <div id="particles-js" class="absolute inset-0 z-0"></div>

    <!-- NAVBAR -->
    <header id="navbar" class="fixed top-0 w-full z-50 backdrop-blur-md bg-gray-900/70 border-b border-gray-700 transition-all duration-300">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center relative z-10">
            <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-purple-500 via-pink-500 to-indigo-500 text-transparent bg-clip-text">
                EventX
            </h1>

            <nav class="hidden md:flex gap-8 font-semibold text-gray-200">
                <a asp-action="Index" class="hover:text-purple-400 transition">Início</a>
                <a asp-action="Eventos" class="hover:text-purple-400 transition">Eventos</a>
                <a asp-action="Contato" class="hover:text-purple-400 transition">Contato</a>
            </nav>

            <div>
                <form method="post" asp-action="Logout">
                    <button type="submit" class="px-5 py-2 rounded-full bg-red-600 hover:bg-red-700 text-white font-semibold shadow-lg transition transform hover:-translate-y-0.5">
                        Sair
                    </button>
                </form>
            </div>
        </div>
    </header>

    <!-- CONTEÚDO -->
    <section class="container mx-auto px-6 py-32 relative z-10">
        <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-8">
            <div class="bg-gray-800 rounded-3xl shadow-xl p-6 flex flex-col items-center">
                <div class="w-28 h-28 rounded-full bg-purple-600 flex items-center justify-center text-white font-bold text-3xl shadow-md">
                    @Model.UserName.Substring(0, 1).ToUpper()
                </div>
                <h2 class="mt-4 text-xl font-bold text-white">@Model.UserName</h2>
                <p class="text-gray-400">@Model.Email</p>
            </div>

            <!-- Formulários -->
            <div class="md:col-span-2 space-y-8">
                <div class="bg-gray-800 rounded-3xl shadow-xl p-8">
                    <h3 class="text-2xl font-bold text-pink-400 mb-6">Seus Dados</h3>
                    <form asp-action="AtualizarConta" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-1">Nome de Usuário</label>
                            <input type="text" name="Nome" value="@Model.UserName" maxlength="50"
                                   class="w-full px-4 py-3 border border-gray-700 rounded-xl focus:ring-2 focus:ring-pink-500 outline-none shadow-sm hover:shadow-md bg-gray-900 text-gray-100">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-1">Email</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">🔒</span>
                                <input readonly type="email" name="Email" value="@Model.Email"
                                       class="w-full px-10 py-3 border border-gray-700 rounded-xl bg-gray-800 text-gray-400 cursor-not-allowed focus:ring-0 outline-none shadow-sm">
                            </div>
                        </div>
                        <div class="md:col-span-2">
                        <div class="md:col-span-2 flex justify-end">
                            <button type="submit"
                                    class="px-6 py-3 bg-pink-500 text-white rounded-xl font-semibold shadow hover:bg-pink-600 transition transform hover:-translate-y-1">
                                Salvar Alterações
                            </button>
                        </div>
                    </form>
                </div>
                <div class="bg-gray-800 rounded-3xl shadow-xl p-8">
                    <h3 class="text-2xl font-bold text-pink-400 mb-6">Alterar Senha</h3>
                    <form asp-action="AlterarSenha" method="post" class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-1">Senha Atual</label>
                            <input type="password" name="senhaAtual"
                                   class="w-full px-4 py-3 border border-gray-700 rounded-xl focus:ring-2 focus:ring-pink-500 outline-none shadow-sm hover:shadow-md bg-gray-900 text-gray-100">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-1">Nova Senha</label>
                            <input type="password" name="novaSenha"
                                   class="w-full px-4 py-3 border border-gray-700 rounded-xl focus:ring-2 focus:ring-pink-500 outline-none shadow-sm hover:shadow-md bg-gray-900 text-gray-100">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-1">Confirmar Nova Senha</label>
                            <input type="password" name="confirmarSenha"
                                   class="w-full px-4 py-3 border border-gray-700 rounded-xl focus:ring-2 focus:ring-pink-500 outline-none shadow-sm hover:shadow-md bg-gray-900 text-gray-100">
                        </div>
                        <div class="flex justify-end">
                            <button type="submit"
                                    class="px-6 py-3 bg-green-600 text-white rounded-xl font-semibold shadow hover:bg-green-700 transition transform hover:-translate-y-1">
                                Atualizar Senha
                            </button>
                        </div>
                    </form>
                    <button type="button" onclick="abrirModalDelecao()"
                            class="flex items-center justify-center w-full px-4 mt-4 py-2 bg-red-500 text-white rounded-full shadow hover:bg-red-600 transition">
                        🗑️ Deletar conta
                    </button>

                    <div id="modal-deletar" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-[9999]">
                        <div class="bg-gray-800 p-8 rounded-3xl shadow-2xl max-w-md w-full relative">
                            <h2 class="text-2xl font-bold text-pink-400 mb-4 text-center">Confirmar exclusão</h2>
                            <p class="text-gray-300 text-sm mb-6 text-center">Digite sua senha para confirmar a exclusão permanente da conta.</p>

                            <form asp-action="DeletarConta" method="post" class="space-y-6">
                                @Html.AntiForgeryToken()
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1">Senha</label>
                                    <input type="password" name="senha" required
                                           class="w-full px-4 py-3 border border-gray-700 rounded-xl focus:ring-2 focus:ring-pink-500 outline-none bg-gray-900 text-gray-100 shadow-sm">
                                </div>

                                <div class="flex justify-between mt-6">
                                    <button type="button" onclick="fecharModalDelecao()"
                                            class="px-5 py-2 bg-gray-700 hover:bg-gray-600 rounded-xl text-gray-200 font-semibold transition">
                                        Cancelar
                                    </button>

                                    <button type="submit"
                                            class="px-5 py-2 bg-red-600 hover:bg-red-700 rounded-xl text-white font-semibold transition">
                                        Confirmar exclusão
                                    </button>
                                </div>
                            </form>

                            <!-- Fechar modal -->
                            <button type="button" onclick="fecharModalDelecao()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-200">
                                ✕
                            </button>
                        </div>
                    </div>

                    <script>
                        function abrirModalDelecao() {
                            document.getElementById('modal-deletar').classList.remove('hidden');
                        }
                        function fecharModalDelecao() {
                            document.getElementById('modal-deletar').classList.add('hidden');
                        }
                    </script>

                </div>
            </div>
        </div>
    </section>

     

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-gray-400 py-12 relative z-10">
        <div class="container mx-auto px-6 grid md:grid-cols-3 gap-8 text-center md:text-left">
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">EventX</h3>
                <p class="text-sm opacity-80">Descubra os melhores eventos da sua cidade e viva novas experiências!</p>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Links</h3>
                <ul class="space-y-2 text-sm">
                    <li><a asp-action="Index" class="hover:text-pink-400 transition">Início</a></li>
                    <li><a asp-action="Eventos" class="hover:text-pink-400 transition">Eventos</a></li>
                    <li><a asp-action="Contato" class="hover:text-pink-400 transition">Contato</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Siga-nos</h3>
                <div class="flex justify-center md:justify-start space-x-4">
                    <a href="#" class="hover:text-pink-400 transition">Instagram</a>
                    <a href="#" class="hover:text-pink-400 transition">Twitter</a>
                    <a href="#" class="hover:text-pink-400 transition">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
<script>
    particlesJS("particles-js", {
      "particles": {
        "number": { "value": 80 },
        "color": { "value": "#ffffff" },
        "shape": { "type": "circle" },
        "opacity": { "value": 0.4 },
        "size": { "value": 3 },
        "line_linked": { "enable": true, "distance": 120, "color": "#ffffff", "opacity": 0.2, "width": 1 },
        "move": { "enable": true, "speed": 0.8, "attract": { "enable": true, "rotateX": 600, "rotateY": 1200 } }
      },
      "interactivity": {
        "events": {
          "onhover": { "enable": true, "mode": "grab" },
          "onclick": { "enable": true, "mode": "push" }
        }
      },
      "retina_detect": true
    });

    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if(window.scrollY > 50){
            navbar.classList.add('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        } else {
            navbar.classList.remove('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        }
    });
</script>
