@{
    ViewData["Title"] = "Todos os Eventos";
}
@model IEnumerable<Projeto_eventos.Models.Evento>

<script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>

<div class="min-h-screen flex flex-col font-sans bg-gray-900 text-gray-100 relative overflow-hidden">

    <!-- Navbar -->
    <header id="navbar" class="fixed top-0 w-full z-50 backdrop-blur-md bg-gray-900/70 border-b border-gray-700 transition-all duration-300">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center relative z-10">
            <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-purple-500 via-pink-500 to-indigo-500 text-transparent bg-clip-text">
                EventX
            </h1>

            <nav class="hidden md:flex gap-8 font-semibold text-gray-200">
                <a asp-action="Index" class="hover:text-purple-400 transition">Início</a>
                <a href="#sobre" class="hover:text-purple-400 transition">Sobre</a>
                <a href="#eventos" class="hover:text-purple-400 transition">Eventos</a>
                <a href="#contato" class="hover:text-purple-400 transition">Contato</a>
            </nav>

            <div class="flex items-center gap-4">
                <a asp-controller="Home" asp-action="PaginaFavoritos" class="px-5 py-2 rounded-full bg-pink-500 hover:bg-pink-600 text-white font-semibold shadow-lg transition transform hover:-translate-y-0.5">
                    Favoritos
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Home" asp-action="Eventos" class="px-5 py-2 rounded-full bg-pink-500 hover:bg-pink-600 text-white font-semibold shadow-lg transition transform hover:-translate-y-0.5">
                        Criar evento
                    </a>
                }

                @if (User.Identity.IsAuthenticated)
                {
                    <div class="relative">
                        <button id="userDropdownButton" class="flex items-center gap-2 px-4 py-2 rounded-full bg-purple-600 hover:bg-purple-700 transition shadow-lg transform hover:-translate-y-0.5">
                            <span>@User.Identity.Name</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-gray-800 rounded-xl shadow-lg overflow-hidden z-50">
                            <a asp-controller="Home" asp-action="Conta" class="block px-4 py-2 text-gray-200 hover:bg-purple-700 hover:text-white transition">Conta</a>
                            <a asp-controller="Home" asp-action="MeusIngressos" class="block px-4 py-2 text-gray-200 hover:bg-purple-700 hover:text-white transition">Meus ingressos</a>
                            <form method="post" asp-controller="Home" asp-action="Logout">
                                <button type="submit" class="w-full text-left px-4 py-2 text-red-500 hover:bg-red-700 hover:text-white transition">Sair</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex gap-3">
                        <a asp-action="Registro" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-full text-white font-semibold shadow transition transform hover:-translate-y-0.5">Registrar</a>
                        <a asp-action="Login" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-full text-white font-semibold shadow transition transform hover:-translate-y-0.5">Entrar</a>
                    </div>
                }
            </div>
        </div>
    </header>

    <section class="relative flex flex-col items-center justify-center text-center px-6 py-28 bg-gradient-to-r from-purple-700 to-indigo-800 mt-20">
        <h2 class="text-5xl md:text-6xl font-extrabold mb-6 leading-tight">Descubra Todos os Eventos</h2>
        <p class="text-lg md:text-xl text-gray-300 mb-8">Shows, palestras, workshops e muito mais — encontre o que combina com você!</p>

        <!-- BARRA DE PESQUISA -->
        <form method="get" asp-action="PesquisarPorNome" class="flex flex-col sm:flex-row justify-center w-full max-w-2xl mb-6">
            <input type="text" name="pesquisa" placeholder="Buscar eventos..."
                   class="flex-1 px-4 py-3 rounded-l-2xl text-gray-900 focus:outline-none shadow">
            <button type="submit" class="px-6 py-3 bg-yellow-400 text-gray-900 font-bold rounded-r-2xl hover:bg-yellow-500 transition">
                🔍 Buscar
            </button>
        </form>

        <!-- FILTROS -->
        <div class="w-full max-w-3xl bg-gray-800/40 backdrop-blur-md border border-gray-700 rounded-2xl p-6 mt-4">
            <h3 class="text-xl font-bold mb-6 text-pink-400 text-center">Filtrar Eventos</h3>

            <form method="get" asp-action="PesquisarTipo">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                    <!-- Preço -->
                    <div class="flex flex-col md:col-span-2">
                        <label class="text-gray-300 text-sm mb-1">Faixa de Preço</label>

                        <div class="grid grid-cols-2 gap-3">
                            <!-- Preço Mínimo -->
                            <input type="number" name="precoMin" placeholder="Mín"
                                   class="w-full px-3 py-2 rounded-lg bg-gray-700 text-gray-200
                      focus:outline-none focus:ring-2 focus:ring-pink-500">

                            <!-- Preço Máximo -->
                            <input type="number" name="precoMax" placeholder="Máx"
                                   class="w-full px-3 py-2 rounded-lg bg-gray-700 text-gray-200
                      focus:outline-none focus:ring-2 focus:ring-pink-500">
                        </div>
                    </div>


                    <!-- Tipo -->
                    <div class="flex flex-col">
                        <label class="text-gray-300 text-sm mb-1">Tipo de Evento</label>
                        <select name="categoria"
                                class="w-full px-3 py-2 rounded-lg bg-gray-700 text-gray-200 focus:outline-none focus:ring-2 focus:ring-pink-500">
                            <option value="">Todos</option>
                            <option value="rock">Rock</option>
                            <option value="pop">Pop</option>
                            <option value="blues">Blues</option>
                            <option value="jazz">Jazz</option>
                            <option value="metal">Metal</option>
                            <option value="teatro">Teatro</option>
                        </select>
                    </div>

                    <!-- Botão -->
                    <div class="flex items-end">
                        <button class="w-full px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white font-semibold rounded-lg transition shadow-md hover:shadow-lg">
                            Aplicar Filtros
                        </button>
                    </div>

                </div>
            </form>
        </div>
        <!---------->

    </section>

    <!-- LISTAGEM DE EVENTOS -->
    <section class="py-20 flex-1">
        <div class="container mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-12 text-pink-500">Todos os Eventos</h2>
            @if (Model != null && Model.Any())
            {
                <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var item in Model)
                    {
                        <div class="bg-gray-800 rounded-3xl shadow-xl overflow-hidden transform transition hover:-translate-y-3 hover:scale-105 hover:shadow-2xl flex flex-col h-full">
                            <div class="relative">
                                <img src="@item.ImagemURL" alt="@item.Nome" class="w-full h-56 object-cover rounded-t-3xl">
                                <span class="absolute top-4 left-4 bg-pink-500 text-white text-sm px-3 py-1 rounded-full shadow">
                                    @item.Data.ToString("dd MMM")
                                </span>
                            </div>

                            <div class="p-6 flex flex-col justify-between flex-1">
                                <div>
                                    <h4 class="text-xl font-bold text-white mb-2">@item.Nome</h4>
                                    <p class="text-gray-300 text-sm leading-relaxed line-clamp-3 mb-3">@item.Descricao</p>
                                </div>

                                <div>
                                    <p class="text-pink-400 text-sm font-medium mb-4">
                                        📍 @item.Local <br>
                                        🕒 @item.Data.ToString("dd 'de' MMMM 'de' yyyy 'às' HH:mm")
                                    </p>

                                    <div class="flex gap-2 items-center">
                                        <a href="@Url.Action("Ingressos", new { id = item.Id })"
                                           class="flex-1 text-center px-4 py-2 bg-purple-600 text-white rounded-full shadow hover:bg-purple-700 transition">
                                            Comprar
                                        </a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a href="@Url.Action("Editar", new { id = item.Id })"
                                               class="flex-1 text-center px-4 py-2 bg-green-600 text-white rounded-full shadow hover:bg-green-700 transition">
                                                Editar
                                            </a>
                                            <a href="@Url.Action("Deletar", new { id = item.Id })"
                                               class="flex-1 text-center px-4 py-2 bg-red-600 text-white rounded-full shadow hover:bg-red-700 transition">
                                                Deletar
                                            </a>
                                        }

                                        <!-- FAVORITO -->
                                        <button onclick="toggleFavorite(this, '@Url.Action("Adicionar", "Home", new { id = item.Id })')"
                                                class="group flex items-center justify-center w-11 h-11 rounded-full bg-gray-700 hover:bg-gray-600 transition relative">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-300 group-hover:text-pink-400 transition-all duration-300"
                                                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 21.364l-7.682-8.682a4.5 4.5 0 010-6.364z" />
                                            </svg>
                                            <div class="absolute inset-0 rounded-full scale-0 bg-pink-500/20 opacity-0 transition-all duration-500 pulse"></div>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-center text-gray-500 mt-10">Nenhum evento encontrado.</p>
            }
        </div>
    </section>

    <!-- Paginas -->
    @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
    {
        <div class="mt-10 flex justify-center space-x-2">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <a asp-action="TodosEventos" asp-route-page="@i"
                   class="px-4 py-2 rounded-lg border transition
                                  @(i == (int)ViewBag.CurrentPage
                                                    ? "bg-pink-500 text-white border-pink-500"
                                                    : "bg-gray-800 text-gray-300 border-gray-600 hover:bg-gray-700")">
            @i
        </a>
                }
        </div>
    }

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-gray-400 py-12 mt-16">
        <div class="container mx-auto px-6 grid md:grid-cols-3 gap-8 text-center md:text-left">
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">EventX</h3>
                <p class="text-sm opacity-80">Descubra os melhores eventos da sua cidade e viva novas experiências!</p>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Links</h3>
                <ul class="space-y-2 text-sm">
                    <li><a href="#" class="hover:text-pink-400 transition">Início</a></li>
                    <li><a href="#" class="hover:text-pink-400 transition">Categorias</a></li>
                    <li><a href="#" class="hover:text-pink-400 transition">Contato</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Siga-nos</h3>
                <div class="flex justify-center md:justify-start space-x-4">
                    <a href="#" class="hover:text-pink-400 transition">Instagram</a>
                    <a href="#" class="hover:text-pink-400 transition">Twitter</a>
                    <a href="#" class="hover:text-pink-400 transition">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<!-- SCRIPTS -->
<script>
    // FAVORITO
    function toggleFavorite(btn, url) {
        const svg = btn.querySelector('svg');
        const pulse = btn.querySelector('.pulse');

        svg.classList.toggle('text-pink-500');
        pulse.classList.remove('scale-0', 'opacity-0');
        pulse.classList.add('scale-150', 'opacity-100');
        setTimeout(() => {
            pulse.classList.add('scale-0', 'opacity-0');
            pulse.classList.remove('scale-150', 'opacity-100');
        }, 400);

        fetch(url).catch(() => {});
    }

    // Navbar dinâmica
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            navbar.classList.add('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        } else {
            navbar.classList.remove('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        }
    });

    // DROPDOWN do usuário
    const dropdownBtn = document.getElementById('userDropdownButton');
    const dropdownMenu = document.getElementById('userDropdownMenu');

    if (dropdownBtn && dropdownMenu) {
        dropdownBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdownMenu.classList.toggle('hidden');
        });

        document.addEventListener('click', (e) => {
            if (!dropdownMenu.classList.contains('hidden') && !dropdownBtn.contains(e.target)) {
                dropdownMenu.classList.add('hidden');
            }
        });
    }
</script>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
