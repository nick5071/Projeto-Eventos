@model Projeto_eventos.Models.EsqueciSenha
@{
    ViewData["Title"] = "Recuperar Senha";
}

<div class="min-h-screen flex items-center justify-center bg-gray-900 text-gray-100">
    <form asp-action="EsqueciSenha" method="post" class="bg-gray-800 p-8 rounded-2xl w-full max-w-md">
        <h2 class="text-2xl font-bold mb-4 text-center">Recuperar senha</h2>
        <label class="block mb-2">Digite seu email cadastrado:</label>
        <input asp-for="Email" class="w-full px-4 py-2 rounded-lg bg-gray-900 border border-gray-700 mb-4" placeholder="exemplo@email.com" />
        <span asp-validation-for="Email" class="text-red-400 text-sm block mb-4"></span>
        <button type="submit" class="inline-block w-full px-6 py-3 bg-purple-600 hover:bg-indigo-500 transition-all duration-200 rounded-xl font-semibold shadow-lg shadow-indigo-900/30">Enviar email</button>
        @if (ViewBag.Mensagem != null)
        {
            <div class="mt-4 p-3 rounded-lg bg-green-900/40 border border-green-600 text-green-400 text-sm">
                @ViewBag.Mensagem
            </div>
        }
    </form>
</div>
