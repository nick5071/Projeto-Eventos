@{
    ViewData["Title"] = "Eventos";
}
@model IEnumerable<Projeto_eventos.Models.Evento>

<script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>

@if (TempData["Sucesso"] != null)
{
    <div id="alerta-sucesso"
         style="z-index:9999"
         class="fixed top-28 left-1/2 transform -translate-x-1/2 bg-green-500/20 border border-green-400 text-green-300 px-6 py-3 rounded-2xl text-center shadow-lg backdrop-blur-md transition-all duration-500 ease-out">
        ✅ @TempData["Sucesso"]
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const alerta = document.getElementById('alerta-sucesso');
            if (alerta) {
                setTimeout(() => {
                    alerta.style.opacity = '0';
                    alerta.style.transform = 'translate(-50%, -20px)';
                    setTimeout(() => alerta.remove(), 200);
                }, 4000);
            }
        });
    </script>
}

<div class="min-h-screen flex flex-col font-sans bg-gray-900 text-gray-100 relative overflow-hidden">

    <!-- NAVBAR -->
    <header id="navbar" class="fixed top-0 w-full z-50 backdrop-blur-md bg-gray-900/70 border-b border-gray-700 transition-all duration-300">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center relative z-10">
            <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-r from-purple-500 via-pink-500 to-indigo-500 text-transparent bg-clip-text">
                EventX
            </h1>

            <nav class="hidden md:flex gap-8 font-semibold text-gray-200">
                <a href="#sobre" class="hover:text-purple-400 transition">Sobre</a>
                <a href="#eventos" class="hover:text-purple-400 transition">Eventos</a>
                <a href="#contato" class="hover:text-purple-400 transition">Contato</a>
            </nav>

            <div class="flex items-center gap-4">
                <a asp-controller="Home" asp-action="PaginaFavoritos" class="px-5 py-2 rounded-full bg-pink-500 hover:bg-pink-600 text-white font-semibold shadow-lg transition transform hover:-translate-y-0.5">
                    Favoritos
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Home" asp-action="Eventos" class="px-5 py-2 rounded-full bg-pink-500 hover:bg-pink-600 text-white font-semibold shadow-lg transition transform hover:-translate-y-0.5">
                        Criar evento
                    </a>
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="relative">
                        <button id="userDropdownButton" class="flex items-center gap-2 px-4 py-2 rounded-full bg-purple-600 hover:bg-purple-700 transition shadow-lg transform hover:-translate-y-0.5">
                            <span>@User.Identity.Name</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-gray-800 rounded-xl shadow-lg overflow-hidden z-50">
                            <a asp-controller="Home" asp-action="Conta" class="block px-4 py-2 text-gray-200 hover:bg-purple-700 hover:text-white transition">Conta</a>
                            <a asp-controller="Home" asp-action="MeusIngressos" class="block px-4 py-2 text-gray-200 hover:bg-purple-700 hover:text-white transition">Meus ingressos</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Home" asp-action="Admin" class="block px-4 py-2 text-gray-200 hover:bg-purple-700 hover:text-white transition">Admin</a>
                            }                           
                            <form method="post" asp-controller="Home" asp-action="Logout">
                                <button type="submit" class="w-full text-left px-4 py-2 text-red-500 hover:bg-red-700 hover:text-white transition">Sair</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex gap-3">
                        <a asp-action="Registro" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-full text-white font-semibold shadow transition transform hover:-translate-y-0.5">Registrar</a>
                        <a asp-action="Login" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded-full text-white font-semibold shadow transition transform hover:-translate-y-0.5">Entrar</a>
                    </div>
                }
            </div>
        </div>
    </header>

    <section class="relative flex-1 flex items-center justify-center text-center px-6 py-36 opacity-0 translate-y-10 transition-all duration-1000" id="hero-section">
        <div id="particles-js" class="absolute inset-0 z-0"></div>
        <div class="relative max-w-3xl z-10">
            <h2 class="text-5xl md:text-6xl font-extrabold mb-6 leading-tight">Descubra eventos incríveis em São Paulo</h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8">Shows, conferências, festivais e muito mais. Viva experiências únicas com a EventX.</p>
            <a href="#eventos" class="px-10 py-3 bg-pink-500 text-white rounded-full font-bold shadow-lg hover:bg-pink-600 transition transform hover:-translate-y-1">Ver Eventos</a>
        </div>
    </section>

    <!-- EVENTOS -->
    <section id="eventos" class="py-24 bg-gray-900 opacity-0 translate-y-10 transition-all duration-1000 reveal-on-scroll">
        <div class="container mx-auto px-6">
            <h3 class="text-4xl font-bold text-center mb-12 text-pink-500">Próximos Eventos</h3>

            <div class="grid gap-12 md:grid-cols-3">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model.Take(3))
                    {
                        <div class="bg-gray-800 rounded-3xl shadow-xl overflow-hidden transform transition hover:-translate-y-4 hover:scale-105 hover:shadow-2xl cursor-pointer flex flex-col h-full">
                            <div class="relative">
                                <img src="@item.ImagemURL" alt="@item.Nome" class="w-full h-64 object-cover rounded-t-3xl">
                                <span class="absolute top-4 left-4 bg-pink-500 text-white text-sm px-3 py-1 rounded-full shadow">@item.Data.ToString("dd MMM")</span>
                            </div>

                            <div class="p-6 flex flex-col justify-between flex-1">
                                <div>
                                    <h4 class="text-xl font-bold text-white mb-2">@item.Nome</h4>
                                    <p class="text-gray-300 text-sm leading-relaxed line-clamp-3 mb-3">@item.Descricao</p>
                                </div>

                                <div>
                                    <p class="text-pink-400 text-sm font-medium mb-4">
                                        📍 @item.Local <br>
                                        🕒 @item.Data.ToString("dd 'de' MMMM 'de' yyyy 'às' HH:mm")
                                    </p>

                                    <div class="flex gap-2 items-center">
                                        <a href="@Url.Action("Ingressos", new { id = item.Id })"
                                           class="flex-1 text-center px-4 py-2 bg-purple-600 text-white rounded-full shadow hover:bg-purple-700 transition">
                                            Comprar
                                        </a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a href="@Url.Action("Editar", new { id = item.Id })"
                                               class="flex-1 text-center px-4 py-2 bg-green-600 text-white rounded-full shadow hover:bg-green-700 transition">
                                                Editar
                                            </a>
                                            <a href="@Url.Action("Deletar", new { id = item.Id })"
                                               class="flex-1 text-center px-4 py-2 bg-red-600 text-white rounded-full shadow hover:bg-red-700 transition">
                                                Deletar
                                            </a>
                                        }

                                        <button onclick="toggleFavorite(this, '@Url.Action("Adicionar", "Home", new { id = item.Id })')"
                                                class="favorite-btn flex items-center gap-2 px-4 py-2 rounded-xl bg-gray-800 hover:bg-gray-700 transition-all duration-300">
                                        
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 class="heart w-5 h-5 transition-all duration-300"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 21.364l-7.682-8.682a4.5 4.5 0 010-6.364z"/>
                                            </svg>
                                        
                                            <span class="text-sm text-gray-300">Favoritar</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-gray-500 col-span-3">Nenhum evento cadastrado ainda.</p>
                }
            </div>

            <div class="flex justify-center mt-12">
                <a asp-action="TodosEventos"
                   class="px-10 py-3 bg-blue-600 text-white rounded-full shadow-lg hover:bg-blue-700 transition transform hover:-translate-y-1">
                    Ver todos os eventos
                </a>
            </div>
        </div>
    </section>

    <!-- CONTATO -->
    <section id="contato" class="py-24 bg-gradient-to-b from-gray-900 to-gray-950 opacity-0 translate-y-10 transition-all duration-1000 reveal-on-scroll">
        <div class="container mx-auto px-6 max-w-5xl text-center">
            <h3 class="text-4xl font-bold text-center mb-12 text-pink-500">Entre em Contato</h3>
            <p class="text-gray-300 mb-10 max-w-2xl mx-auto">Tem alguma dúvida, sugestão ou quer fazer parceria? Envie uma mensagem e entraremos em contato o quanto antes!</p>

            <form method="post" class="grid gap-6 md:grid-cols-2 bg-gray-800/60 backdrop-blur-md p-8 rounded-3xl shadow-lg border border-gray-700">
                <input type="text" name="Nome" placeholder="Seu nome" required class="px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-gray-100 focus:border-pink-500 outline-none transition"/>
                <input type="email" name="Email" placeholder="Seu email" required class="px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-gray-100 focus:border-pink-500 outline-none transition"/>
                <textarea name="Mensagem" placeholder="Digite sua mensagem..." rows="5" class="md:col-span-2 px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-gray-100 focus:border-pink-500 outline-none transition"></textarea>
                <button type="submit" class="md:col-span-2 px-8 py-3 bg-pink-600 hover:bg-pink-700 rounded-full font-semibold text-white shadow-lg transition transform hover:-translate-y-1">Enviar</button>
            </form>

            <div class="mt-12 grid md:grid-cols-3 gap-8 text-gray-400">
                <div>
                    <h4 class="text-lg font-semibold text-white mb-2">📍 Endereço</h4>
                    <p>Av. Paulista, 1000 - São Paulo, SP</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-white mb-2">📞 Telefone</h4>
                    <p>(11) 99999-9999</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold text-white mb-2">✉️ Email</h4>
                    <p>contato@eventx.com</p>
                </div>
            </div>

            <div class="mt-12">
                <iframe class="w-full h-64 rounded-2xl border-0 shadow-md"
                        src="https://maps.google.com/maps?q=sao%20paulo&t=&z=13&ie=UTF8&iwloc=&output=embed"></iframe>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-gray-400 py-12">
        <div class="container mx-auto px-6 grid md:grid-cols-3 gap-8 text-center md:text-left">
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">EventX</h3>
                <p class="text-sm opacity-80">Descubra os melhores eventos da sua cidade e viva novas experiências!</p>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Links</h3>
                <ul class="space-y-2 text-sm">
                    <li><a href="#sobre" class="hover:text-pink-400 transition">Sobre</a></li>
                    <li><a href="#eventos" class="hover:text-pink-400 transition">Eventos</a></li>
                    <li><a href="#contato" class="hover:text-pink-400 transition">Contato</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-white mb-2">Siga-nos</h3>
                <div class="flex justify-center md:justify-start space-x-4">
                    <a href="#" class="hover:text-pink-400 transition">Instagram</a>
                    <a href="#" class="hover:text-pink-400 transition">Twitter</a>
                    <a href="#" class="hover:text-pink-400 transition">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<script>

    particlesJS("particles-js", {
        "particles": {
            "number": { "value": 80 },
            "color": { "value": "#ffffff" },
            "shape": { "type": "circle" },
            "opacity": { "value": 0.4 },
            "size": { "value": 3 },
            "line_linked": { "enable": true, "distance": 120, "color": "#ffffff", "opacity": 0.2, "width": 1 },
            "move": { "enable": true, "speed": 0.8 }
        },
        "retina_detect": true
    });

    // Função do botão de favorito
    function toggleFavorite(btn, url) {
        const svg = btn.querySelector('svg');
        const pulse = btn.querySelector('.pulse');
        svg.classList.toggle('text-pink-500');
        pulse.classList.remove('scale-0', 'opacity-0');
        pulse.classList.add('scale-150', 'opacity-100');
        setTimeout(() => {
            pulse.classList.add('scale-0', 'opacity-0');
            pulse.classList.remove('scale-150', 'opacity-100');
        }, 400);
        fetch(url).catch(() => {});
    }

    // Animações de aparição ao rolar a tela
    const reveals = document.querySelectorAll('.reveal-on-scroll');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if(entry.isIntersecting){
                entry.target.classList.remove('opacity-0', 'translate-y-10');
            }
        });
    }, { threshold: 0.2 });
    reveals.forEach(el => observer.observe(el));

    window.addEventListener('load', () => {
        document.getElementById('hero-section').classList.remove('opacity-0', 'translate-y-10');
    });

    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if(window.scrollY > 50){
            navbar.classList.add('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        } else {
            navbar.classList.remove('bg-gray-900/80', 'backdrop-blur-md', 'shadow-md');
        }
    });

    // Dropdown 
    const dropdownBtn = document.getElementById('userDropdownButton');
    const dropdownMenu = document.getElementById('userDropdownMenu');
    if (dropdownBtn && dropdownMenu) {
        dropdownBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdownMenu.classList.toggle('hidden');
        });
        document.addEventListener('click', (e) => {
            if (!dropdownMenu.classList.contains('hidden') && !dropdownBtn.contains(e.target)) {
                dropdownMenu.classList.add('hidden');
            }
        });
    }
</script>

<style>

    /* descrição */
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .favorite-btn:hover .heart {
        color: #ec4899;
        transform: scale(1.15);
    }

    .favorite-btn.active .heart {
        fill: #ec4899;
        color: #ec4899;
    }
</style>
