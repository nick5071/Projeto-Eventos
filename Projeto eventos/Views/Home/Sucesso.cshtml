@model Projeto_eventos.Models.SucessoPagamentoViewModel

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">

    <div class="bg-white shadow-2xl rounded-3xl max-w-2xl w-full p-10 text-center">

        <!-- Ícone -->
        <div class="flex justify-center mb-6">
            <div class="bg-green-100 text-green-600 rounded-full p-4">
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-12 w-12"
                     fill="none"
                     viewBox="0 0 24 24"
                     stroke="currentColor">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7" />
                </svg>
            </div>
        </div>

        <h1 class="text-3xl font-extrabold text-green-600 mb-2">
            Pagamento aprovado!
        </h1>

        <p class="text-gray-600 mb-8">
            Seu ingresso foi comprado com sucesso 🎉
        </p>

        <!-- Dados do Evento -->
        <div class="bg-gray-50 rounded-2xl p-6 text-left space-y-4">

            <div>
                <span class="font-semibold">Evento:</span>
                <p class="text-lg">@Model.Evento.Nome</p>
            </div>

            <div>
                <span class="font-semibold">Data:</span>
                <p>@Model.Evento.Data.ToString("dd 'de' MMMM 'de' yyyy 'às' HH:mm")</p>
            </div>

            <div>
                <span class="font-semibold">Local:</span>
                <p>@Model.Evento.Local</p>
            </div>

            <div>
                <span class="font-semibold">Tipo de ingresso:</span>
                <p>@Model.EventoDados.TipoIngresso</p>
            </div>


            <div>
                <span class="font-semibold">Valor pago:</span>
                <p class="text-lg text-green-600 font-bold">
                    R$ @Model.ValorFinal.ToString("N2")
                </p>
            </div>

        </div>

        <!-- Ações -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">

            <a href="@Url.Action("Index", "Home")"
               class="px-6 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 font-semibold">
                Voltar para Home
            </a>

            <a asp-controller="Home"
               asp-action="MeusIngressos"
               class="px-6 py-3 border border-indigo-600 text-indigo-600 rounded-xl hover:bg-indigo-50 font-semibold">
                Meus ingressos
            </a>

        </div>
    </div>

</div>
